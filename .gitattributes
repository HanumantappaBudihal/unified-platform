# Force LF on shell scripts and configs so they run correctly inside Linux
# containers regardless of the host checkout (this class of bug broke the
# Postgres init script: `#!/bin/bash` + CRLF -> "/bin/bash^M: bad interpreter").
*.sh            text eol=lf
*.bash          text eol=lf
Dockerfile      text eol=lf
*.yaml          text eol=lf
*.yml           text eol=lf
*.json          text eol=lf
*.rego          text eol=lf
*.conf          text eol=lf

# Normalize line endings on commit; let git decide text vs binary otherwise.
* text=auto
