# ─── Keycloak (for JWT validation) ───
KEYCLOAK_URL=http://host.docker.internal:8080
KEYCLOAK_REALM=infrastructure

# ─── Monitoring ───
KONG_PROMETHEUS_PORT=9098
KONG_GRAFANA_PORT=3011
GRAFANA_ADMIN_PASSWORD=change-me
