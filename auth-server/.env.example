# ===========================================
# Auth Server (Keycloak + OPA) - Environment Config
# ===========================================
# Copy this file to .env and fill in your secrets:
#   cp .env.example .env

# Keycloak Admin
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME

# Keycloak Database (PostgreSQL)
KC_DB_NAME=keycloak
KC_DB_USER=keycloak
KC_DB_PASSWORD=CHANGE_ME
