{
  "realm": "infrastructure",
  "enabled": true,
  "displayName": "Infrastructure Services",
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "smtpServer": {
    "host": "email-mailpit",
    "port": "1025",
    "from": "noreply@infrastructure.local",
    "fromDisplayName": "Infrastructure Services",
    "ssl": "false",
    "starttls": "false",
    "auth": "false"
  },
  "bruteForceProtected": true,
  "permanentLockout": false,
  "maxFailureWaitSeconds": 900,
  "minimumQuickLoginWaitSeconds": 60,
  "waitIncrementSeconds": 60,
  "quickLoginCheckMilliSeconds": 1000,
  "maxDeltaTimeSeconds": 43200,
  "failureFactor": 5,
  "roles": {
    "realm": [
      {
        "name": "infra-admin",
        "description": "Full access to all infrastructure portals and settings"
      },
      {
        "name": "infra-viewer",
        "description": "Read-only access to infrastructure portals"
      },
      {
        "name": "platform-admin",
        "description": "Full access to platform management (app onboarding, teams, audit)"
      }
    ]
  },
  "clients": [
    {
      "clientId": "gateway-portal",
      "name": "Unified Gateway Portal",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "gateway-portal-secret",
      "redirectUris": ["http://localhost:3006/*"],
      "webOrigins": ["http://localhost:3006"],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "defaultClientScopes": ["openid", "profile", "email", "roles"]
    },
    {
      "clientId": "kafka-portal",
      "name": "Kafka Event Streaming Portal",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "kafka-portal-secret",
      "redirectUris": ["http://localhost:3000/*"],
      "webOrigins": ["http://localhost:3000"],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "defaultClientScopes": ["openid", "profile", "email", "roles"]
    },
    {
      "clientId": "cache-portal",
      "name": "Redis Cache Portal",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "cache-portal-secret",
      "redirectUris": ["http://localhost:3002/*"],
      "webOrigins": ["http://localhost:3002"],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "defaultClientScopes": ["openid", "profile", "email", "roles"]
    },
    {
      "clientId": "storage-portal",
      "name": "MinIO Object Storage Portal",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "storage-portal-secret",
      "redirectUris": ["http://localhost:3004/*"],
      "webOrigins": ["http://localhost:3004"],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "defaultClientScopes": ["openid", "profile", "email", "roles"]
    },
    {
      "clientId": "grafana",
      "name": "Grafana Monitoring",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "grafana-oidc-secret",
      "redirectUris": [
        "http://localhost:3001/*",
        "http://localhost:3003/*",
        "http://localhost:3005/*"
      ],
      "webOrigins": [
        "http://localhost:3001",
        "http://localhost:3003",
        "http://localhost:3005"
      ],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "defaultClientScopes": ["openid", "profile", "email", "roles"]
    },
    {
      "clientId": "minio-console",
      "name": "MinIO Console",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "minio-console-oidc-secret",
      "redirectUris": ["http://localhost:9001/*"],
      "webOrigins": ["http://localhost:9001"],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "defaultClientScopes": ["openid", "profile", "email", "roles"]
    },
    {
      "clientId": "authz-portal",
      "name": "Authorization Portal",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "authz-portal-secret",
      "redirectUris": ["http://localhost:3012/*"],
      "webOrigins": ["http://localhost:3012"],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "defaultClientScopes": ["openid", "profile", "email", "roles"]
    },
    {
      "clientId": "logging-portal",
      "name": "Centralized Logging Portal",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "logging-portal-secret",
      "redirectUris": ["http://localhost:3007/*"],
      "webOrigins": ["http://localhost:3007"],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "defaultClientScopes": ["openid", "profile", "email", "roles"]
    },
    {
      "clientId": "health-portal",
      "name": "Health Aggregation Portal",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "health-portal-secret",
      "redirectUris": ["http://localhost:3009/*"],
      "webOrigins": ["http://localhost:3009"],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "defaultClientScopes": ["openid", "profile", "email", "roles"]
    }
  ],
  "clientScopes": [
    {
      "name": "roles",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true"
      },
      "protocolMappers": [
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "realm_access.roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "admin",
      "email": "admin@infrastructure.local",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Infra",
      "lastName": "Admin",
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ],
      "realmRoles": ["infra-admin", "platform-admin"]
    },
    {
      "username": "viewer",
      "email": "viewer@infrastructure.local",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Infra",
      "lastName": "Viewer",
      "credentials": [
        {
          "type": "password",
          "value": "viewer",
          "temporary": false
        }
      ],
      "realmRoles": ["infra-viewer"]
    }
  ]
}
