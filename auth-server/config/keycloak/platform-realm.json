{
  "realm": "platform",
  "enabled": true,
  "sslRequired": "none",
  "loginWithEmailAllowed": true,
  "roles": {
    "realm": [
      { "name": "owner", "description": "Tenant owner" },
      { "name": "admin", "description": "Tenant admin" },
      { "name": "developer", "description": "Tenant developer" },
      { "name": "viewer", "description": "Tenant viewer" }
    ]
  },
  "clients": [
    {
      "clientId": "gateway-portal",
      "name": "Unified Gateway Portal",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "gateway-portal-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": ["http://localhost:3006/*"],
      "webOrigins": ["*"],
      "defaultClientScopes": ["openid", "profile", "email", "roles"],
      "protocolMappers": [
        {
          "name": "tenant",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "tenant",
            "claim.name": "tenant",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "alice",
      "enabled": true,
      "email": "alice@acme.example",
      "firstName": "Alice",
      "lastName": "Owner",
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "alice-pass", "temporary": false }],
      "attributes": { "tenant": ["acme-corp"] },
      "realmRoles": ["owner"]
    },
    {
      "username": "bob",
      "enabled": true,
      "email": "bob@globex.example",
      "firstName": "Bob",
      "lastName": "Viewer",
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "bob-pass", "temporary": false }],
      "attributes": { "tenant": ["globex-inc"] },
      "realmRoles": ["viewer"]
    }
  ]
}
