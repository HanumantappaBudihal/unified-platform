# ── Seiton Platform IdP (OIDC) ────────────────────────────────────────────────
# The authz portal authenticates operators against the Seiton Platform IdP.
# Leave PLATFORM_ISSUER (or the client id / secret) empty to run OPEN for local
# development — middleware then does not gate.
PLATFORM_ISSUER=http://localhost:8081
OIDC_CLIENT_ID=authz-portal
OIDC_CLIENT_SECRET=

# NextAuth — required when SSO is enabled.
NEXTAUTH_URL=http://localhost:3008
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=

# OPA (existing)
OPA_URL=http://localhost:8181
