# ===========================================
# Backup Server - Environment Config
# ===========================================
# Copy this file to .env and fill in your secrets:
#   cp .env.example .env

# --- Redis ---
REDIS_ADMIN_PASSWORD=CHANGE_ME

# --- MinIO ---
MINIO_ROOT_USER=CHANGE_ME
MINIO_ROOT_PASSWORD=CHANGE_ME

# --- Backup Settings ---
BACKUP_DIR=/backup/data
BACKUP_RETENTION_DAYS_REDIS=7
BACKUP_RETENTION_DAYS_MINIO=30
BACKUP_RETENTION_DAYS_KAFKA=30
