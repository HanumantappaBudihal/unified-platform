# ===========================================
# Cache Server (Redis Cluster) - Environment Config
# ===========================================
# Copy this file to .env and fill in your secrets:
#   cp .env.example .env

# Host IP for access from other devices on the network
HOST_IP=192.168.11.96

# Redis admin credentials
REDIS_ADMIN_USER=admin
REDIS_ADMIN_PASSWORD=CHANGE_ME

# Redis app credentials
REDIS_SESSION_SVC_PASSWORD=CHANGE_ME
REDIS_CATALOG_SVC_PASSWORD=CHANGE_ME

# Redis memory per node
REDIS_MAXMEMORY=256mb

# Portal port
PORTAL_PORT=3002

# Grafana
GRAFANA_ADMIN_PASSWORD=CHANGE_ME
