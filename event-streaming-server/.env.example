# ===========================================
# Kafka Central Server - Environment Config
# ===========================================
# Copy this file to .env and fill in your secrets:
#   cp .env.example .env

# Kafka
KAFKA_BROKER_ID=1
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk

# Host IP for external Kafka access (other devices on your network)
HOST_IP=192.168.11.96

# Ports
KAFKA_PORT=9092
KAFKA_UI_PORT=8080
SCHEMA_REGISTRY_PORT=8081
KAFKA_CONNECT_PORT=8083
KAFKA_REST_PROXY_PORT=8082
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Kafka UI
KAFKA_UI_CLUSTER_NAME=kafka-central

# Kafka UI Authentication (RBAC)
KAFKA_UI_ADMIN_USER=admin
KAFKA_UI_ADMIN_PASSWORD=CHANGE_ME
KAFKA_UI_VIEWER_USER=viewer
KAFKA_UI_VIEWER_PASSWORD=CHANGE_ME

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# Kafka SASL/SCRAM (Phase 4 - Secure profile)
KAFKA_ADMIN_USER=admin
KAFKA_ADMIN_PASSWORD=CHANGE_ME

# Alerting (Grafana + Prometheus)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
# ALERT_EMAIL=ops-team@company.com
