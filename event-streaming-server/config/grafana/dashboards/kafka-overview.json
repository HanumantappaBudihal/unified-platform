{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": ":: BROKER HEALTH ::",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "Broker Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "kafka_controller_active_controller_count",
          "legendFormat": "Active Controllers"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "1": { "text": "HEALTHY", "color": "green" }, "0": { "text": "DOWN", "color": "red" } } }
          ]
        }
      }
    },
    {
      "title": "Under-Replicated Partitions",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "targets": [
        {
          "expr": "kafka_server_underreplicated_partitions",
          "legendFormat": "Under-replicated"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "title": "Partition Count",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "targets": [
        {
          "expr": "kafka_server_replicamanager_partitioncount",
          "legendFormat": "Partitions"
        }
      ]
    },
    {
      "title": "Leader Count",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "targets": [
        {
          "expr": "kafka_server_replicamanager_leadercount",
          "legendFormat": "Leaders"
        }
      ]
    },
    {
      "title": "JVM Heap Usage",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "targets": [
        {
          "expr": "jvm_heap_memory_used_bytes / jvm_heap_memory_max_bytes * 100",
          "legendFormat": "Heap %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "title": "Request Handler Idle %",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "targets": [
        {
          "expr": "kafka_server_requesthandlerpool_avg_idle_percent * 100",
          "legendFormat": "Idle %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 30 },
              { "color": "green", "value": 60 }
            ]
          }
        }
      }
    },
    {
      "title": ":: THROUGHPUT ::",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "title": "Messages In Per Second",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "kafka_server_brokertopicmetrics_messagesinpersec_rate",
          "legendFormat": "Messages In/s (all topics)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2, "pointSize": 5 }
        }
      }
    },
    {
      "title": "Bytes In / Out Per Second",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "kafka_server_brokertopicmetrics_bytesinpersec_rate",
          "legendFormat": "Bytes In/s"
        },
        {
          "expr": "kafka_server_brokertopicmetrics_bytesoutpersec_rate",
          "legendFormat": "Bytes Out/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2 }
        }
      }
    },
    {
      "title": "Messages In Per Topic",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "sum by (topic) (rate(kafka_topic_partition_current_offset[5m]))",
          "legendFormat": "{{ topic }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "bars", "fillOpacity": 50, "lineWidth": 1, "stacking": { "mode": "normal" } }
        }
      }
    },
    {
      "title": "Request Rate by Type",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [
        {
          "expr": "rate(kafka_network_requestmetrics_requests_total[5m])",
          "legendFormat": "{{ request }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 }
        }
      }
    },
    {
      "title": ":: CONSUMER LAG (kafka-exporter) ::",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "collapsed": false
    },
    {
      "title": "Consumer Group Lag (Total per Group)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "targets": [
        {
          "expr": "sum by (consumergroup) (kafka_consumergroup_lag)",
          "legendFormat": "{{ consumergroup }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 5000 }
            ]
          }
        }
      }
    },
    {
      "title": "Consumer Lag by Topic & Group",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "targets": [
        {
          "expr": "sum by (consumergroup, topic) (kafka_consumergroup_lag)",
          "legendFormat": "{{ consumergroup }} → {{ topic }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 }
        }
      }
    },
    {
      "title": "Consumer Group Members",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 31 },
      "targets": [
        {
          "expr": "kafka_consumergroup_members",
          "legendFormat": "{{ consumergroup }}",
          "instant": true,
          "format": "table"
        }
      ]
    },
    {
      "title": "Topic Partition Offsets (Current)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 31 },
      "targets": [
        {
          "expr": "sum by (topic) (kafka_topic_partition_current_offset)",
          "legendFormat": "{{ topic }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 }
        }
      }
    },
    {
      "title": ":: DEAD LETTER QUEUES ::",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 39 },
      "collapsed": false
    },
    {
      "title": "DLQ Message Count",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 40 },
      "targets": [
        {
          "expr": "sum(kafka_topic_partition_current_offset{topic=~\".*\\\\.dlq|.*-dlq|_connect-dlq\"})",
          "legendFormat": "Total DLQ Messages"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      }
    },
    {
      "title": "DLQ Messages Per Topic",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 16, "x": 8, "y": 40 },
      "targets": [
        {
          "expr": "sum by (topic) (kafka_topic_partition_current_offset{topic=~\".*\\\\.dlq|.*-dlq|_connect-dlq\"})",
          "legendFormat": "{{ topic }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "bars", "fillOpacity": 60, "lineWidth": 1 }
        }
      }
    },
    {
      "title": ":: RESOURCES ::",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 46 },
      "collapsed": false
    },
    {
      "title": "Log Size Per Topic",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 47 },
      "targets": [
        {
          "expr": "sum by (topic) (kafka_log_log_size_bytes)",
          "legendFormat": "{{ topic }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2 }
        }
      }
    },
    {
      "title": "GC Collection Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 47 },
      "targets": [
        {
          "expr": "rate(jvm_gc_collection_time_ms_total[5m])",
          "legendFormat": "{{ gc }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2 }
        }
      }
    },
    {
      "title": "JVM Threads",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 55 },
      "targets": [
        {
          "expr": "jvm_threads_current",
          "legendFormat": "Threads"
        }
      ]
    },
    {
      "title": "Heap Used (Bytes)",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 18, "x": 6, "y": 55 },
      "targets": [
        {
          "expr": "jvm_heap_memory_used_bytes",
          "legendFormat": "Used"
        },
        {
          "expr": "jvm_heap_memory_max_bytes",
          "legendFormat": "Max"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },
    {
      "title": ":: ALERTS ::",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 59 },
      "collapsed": false
    },
    {
      "title": "Active Prometheus Alerts",
      "type": "table",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 60 },
      "targets": [
        {
          "expr": "ALERTS{alertstate=\"firing\"}",
          "legendFormat": "{{ alertname }}",
          "instant": true,
          "format": "table"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["kafka", "monitoring", "central"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Kafka Central - Overview",
  "uid": "kafka-central-overview",
  "version": 2
}
