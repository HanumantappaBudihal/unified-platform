# ===========================================
# Object Storage Server (MinIO) - Environment Config
# ===========================================
# Copy this file to .env and fill in your secrets:
#   cp .env.example .env

# MinIO root credentials
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=CHANGE_ME

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# Application credentials (used by init-buckets.sh)
MINIO_DOCUMENT_SVC_KEY=document-svc-key
MINIO_DOCUMENT_SVC_SECRET=CHANGE_ME
MINIO_MEDIA_SVC_KEY=media-svc-key
MINIO_MEDIA_SVC_SECRET=CHANGE_ME
MINIO_HR_PORTAL_KEY=hr-portal-key
MINIO_HR_PORTAL_SECRET=CHANGE_ME
MINIO_ANALYTICS_SVC_KEY=analytics-svc-key
MINIO_ANALYTICS_SVC_SECRET=CHANGE_ME
