# ─── Platform API ───
PLATFORM_API_PORT=3020

# ─── Platform Database ───
PLATFORM_DB_HOST=shared-postgres
PLATFORM_DB_PORT=5432
PLATFORM_DB_NAME=platform_db
PLATFORM_DB_USER=platform_user
PLATFORM_DB_PASSWORD=platform-db-secret

# ─── PostgreSQL Admin (for creating app databases) ───
PG_ADMIN_HOST=shared-postgres
PG_ADMIN_PORT=5432
PG_ADMIN_USER=postgres
PG_ADMIN_PASSWORD=postgres-admin-secret

# ─── Redis Cluster ───
REDIS_HOST=redis-node-1
REDIS_PORT=6371
REDIS_ADMIN_PASSWORD=admin-secret

# ─── Kafka ───
KAFKA_BROKERS=kafka:9092

# ─── MinIO ───
MINIO_ENDPOINT=storage-nginx
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin-secret
MINIO_USE_SSL=false

# ─── Keycloak Admin ───
KEYCLOAK_URL=http://auth-keycloak:8080
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# ─── OPA ───
OPA_URL=http://authz-opa:8181

# ─── Kong Admin ───
KONG_ADMIN_URL=http://kong:8001
