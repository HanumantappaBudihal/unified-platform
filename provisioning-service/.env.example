# ===========================================
# Provisioning Service — Environment Config
# Copy to .env:  cp .env.example .env
# ===========================================

PORT=3030

# ── Auth (preferred): Seiton Platform token introspection (RFC 7662) ──────────
# When these are set, every call must carry a Platform-issued Bearer token that
# introspects active and carries PLATFORM_REQUIRED_SCOPE. ClientId/Secret MUST
# match the seeded `infra-provisioning` OpenIddict client on the Platform.
PLATFORM_INTROSPECT_URL=http://api:8081/connect/introspect
PLATFORM_CLIENT_ID=infra-provisioning
PLATFORM_CLIENT_SECRET=
PLATFORM_REQUIRED_SCOPE=infra.provision

# ── Auth (legacy fallback): single shared bearer token ────────────────────────
# Used only when the PLATFORM_* introspection vars above are NOT set. Leave both
# empty ONLY for local dev (the service then runs open and logs a warning).
PROVISIONING_API_TOKEN=

# Comma-separated list of resource types this deployment may provision.
ENABLED_RESOURCES=kafka,redis,minio,postgres,gateway

# --- Kafka ---
KAFKA_BROKERS=kafka:9092

# --- Redis (cluster entrypoint) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- MinIO (admin/root creds; mc must be on PATH for IAM ops) ---
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# --- Postgres (admin/superuser; only touches the `postgres` maintenance DB) ---
PGADMIN_HOST=postgres
PGADMIN_PORT=5432
PGADMIN_USER=postgres
PGADMIN_PASSWORD=postgres

# --- Gateway (Kong admin API) ---
KONG_ADMIN_URL=http://api-gateway:8001
