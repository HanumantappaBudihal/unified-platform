# ===========================================
# SMTP Configuration (add to your app's .env)
# ===========================================

# Local dev (Mailpit) — these are the defaults, no changes needed
SMTP_HOST=email-mailpit
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_FROM=noreply@app.local

# Production — uncomment and configure:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=your-sendgrid-api-key
# SMTP_FROM=noreply@yourdomain.com
