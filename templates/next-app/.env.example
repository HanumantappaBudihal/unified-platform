# Generated by IDP Platform — fill with values from `platform status --credentials`
APP_NAME={{APP_NAME}}

# Auth (NextAuth + Keycloak)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me
KEYCLOAK_ISSUER=http://localhost:8080/realms/applications
KEYCLOAK_CLIENT_ID={{APP_NAME}}-dev
KEYCLOAK_CLIENT_SECRET=

# MinIO (file uploads)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=dev-{{APP_NAME}}
