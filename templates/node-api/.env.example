# Generated by IDP Platform — fill with values from `platform status --credentials`
APP_NAME={{APP_NAME}}
PORT=3000

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USER=
REDIS_PASSWORD=
REDIS_KEY_PREFIX=dev:{{APP_NAME}}:

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_PREFIX=dev.{{APP_NAME}}

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=dev-{{APP_NAME}}

# Auth (Keycloak)
KEYCLOAK_ISSUER=http://localhost:8080/realms/applications
KEYCLOAK_CLIENT_ID={{APP_NAME}}-dev
KEYCLOAK_CLIENT_SECRET=
