# ── Seiton Platform IdP (OIDC) ────────────────────────────────────────────────
# The portal authenticates operators against the Seiton Platform IdP. Leave
# PLATFORM_ISSUER (or the client id / secret) empty to run the portal OPEN for
# local development — middleware then does not gate.
PLATFORM_ISSUER=http://localhost:8081
OIDC_CLIENT_ID=gateway-portal
OIDC_CLIENT_SECRET=

# NextAuth — required when SSO is enabled.
NEXTAUTH_URL=http://localhost:3000
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=
